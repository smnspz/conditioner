CONDITIONER_JWT_SECRET_KEY=
CONDITIONER_TOKEN_ENCRYPTION_KEY=
CONDITIONER_DEV_MODE=false
CONDITIONER_GEMINI_API_KEY=

# Which WorkoutGenerationProvider adapter is active: "gemini" (default) or "cloudflare".
CONDITIONER_WORKOUT_GENERATION_ENGINE=gemini

# Which persistence adapter backs every repository port: "sqlite" (for local development) or "d1".
CONDITIONER_PERSISTENCE_ENGINE=sqlite

# Required when CONDITIONER_WORKOUT_GENERATION_ENGINE=cloudflare or
# CONDITIONER_PERSISTENCE_ENGINE=d1.
CONDITIONER_CLOUDFLARE_ACCOUNT_ID=
CONDITIONER_CLOUDFLARE_API_TOKEN=
# Required only when CONDITIONER_PERSISTENCE_ENGINE=d1.
CONDITIONER_CLOUDFLARE_D1_DATABASE_ID=
